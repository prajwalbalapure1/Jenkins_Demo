pipeline {
    agent any 

    tools {
        jdk 'jdk17'
        maven 'maven3'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }
    stages {
        stage("git checkout") {
            steps {
                git branch: 'master',
                credentialsId: 'git-cred',
                url: 'https://github.com/prajwalbalapure1/Jenkins_Demo.git'
            }
        }
         stage('debug') {
            steps {
                sh 'ls -R'
            }
        }
        stage('build') {
            steps {
                sh 'mvn compile -f springboot-angular-helloworld-main/backend/helloworld'
            }
        }
        stage('test') {
            steps {
                sh 'mvn test -f springboot-angular-helloworld-main/backend/helloworld'
            }
        }
        stage('sonaQube analysis') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh ''' 
                    $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectName=springboot-angular-helloworld-main \
                        -Dsonar.projectKey=springboot-angular-helloworld-main \
                        -Dsonar.java.binaries=springboot-angular-helloworld-main/backend/helloworld/target/classes \
                        -Dsonar.sources=springboot-angular-helloworld-main/backend/helloworld/src/main \
                        -Dsonar.tests=springboot-angular-helloworld-main/backend/helloworld/src/test \
                    '''
                }
            }
        }
        stage('quality gate') {
            steps {
                timeout(time: 1, unit: 'HOURS') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
        stage('package') {
            steps {
                sh 'mvn package -f springboot-angular-helloworld-main/backend/helloworld'
            }
        }
    }
}
